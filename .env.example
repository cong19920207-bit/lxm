# 环境变量模板，复制为 .env 并填写实际值

# === MySQL ===
MYSQL_HOST=
MYSQL_PORT=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
# Docker Compose：mysql 服务 root 密码（可选，未设时 compose 默认 root123456，须与宿主机 .env 中 MYSQL_* 一并视为一套）
# MYSQL_ROOT_PASSWORD=

# === Redis ===
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
REDIS_DB=
# 用户短期情绪缓存 TTL（秒），键 user_emotion:{user_id}；默认 3600
# REDIS_USER_EMOTION_TTL=3600

# === JWT ===
JWT_SECRET=
JWT_ALGORITHM=
JWT_EXPIRE_HOURS=

# === Open API Key（必填，长度≥32；与 JWT 无关；测试/生产各一套）===
# 生成示例：openssl rand -hex 32
OPEN_API_PEPPER=
# v1 不读取，仅预留：OPEN_API_PUBLIC_BASE_URL=http://cllxm.com

# === 火山引擎（豆包 LLM）===
VOLC_ACCESS_KEY=
VOLC_SECRET_KEY=
VOLC_ENDPOINT=
VOLC_MODEL=
# 通用 LLM 超时（秒），默认 45；日记、Agent、记忆提取、后台配置测试集等使用（与对话质量同类）
# LLM_TIMEOUT=45
# H5 对话 send/resend 同链路专用，默认 45
# LLM_TIMEOUT_CHAT=45
# 对话合并调度防抖（毫秒），默认 500
# CHAT_DEBOUNCE_MS=500

# === 阿里云（Embedding + DashVector）===
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_EMBEDDING_ENDPOINT=
ALIYUN_EMBEDDING_MODEL=
# 角色知识库 CRUD（管理后台 STEP-027）、Step2/Step6 向量检索均依赖
DASHVECTOR_API_KEY=
DASHVECTOR_ENDPOINT=
DASHVECTOR_COLLECTION_NAME=

# === 后台管理员 JWT ===
# 仅为不可运行的占位示例；启动前必须替换为自定义密钥
ADMIN_JWT_SECRET=your_admin_jwt_secret_here

# === 应用配置 ===
APP_DEBUG=
APP_HOST=
APP_PORT=
CORS_ORIGINS=

# Open API Key 哈希 pepper（≥32，与 JWT 无关）
OPEN_API_PEPPER=

# ============================================================
# === 生活流系统（LIFE / FEED）新增环境变量（§0.4 一次性写入）===
# ============================================================

# === DeepSeek LLM（LLM-01~07 独立模型客户端，M1 STEP-002 引入）===
# 技术凭证一律不进后台 UI；缺失时启动阶段 WARN，不阻断服务
DEEPSEEK_API_KEY=
# 默认 https://api.deepseek.com
DEEPSEEK_BASE_URL=

# === LiblibAI 图像生成（M1 STEP-012 引入）===
# HMAC-SHA1 签名用（AccessKey / SecretKey / Timestamp / SignatureNonce）
LIBLIB_ACCESS_KEY=
LIBLIB_SECRET_KEY=
LIBLIB_BASE_URL=

# === 阿里云 OSS（存 feed_post 图片，M1 STEP-012 引入）===
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=
OSS_BUCKET=
# OSS 对应 CDN 加速域名（写入 feed_post.image_urls 的最终 URL 前缀）
OSS_CDN_DOMAIN=

# === 生活流参考图（供 LiblibAI 公网拉取 base.png，附录 A-3）===
# 生产域名的完整 URL，如 https://cllxm.com/static/images/avatar/character-ref/base.png
FEED_IMAGE_REFERENCE_PUBLIC_URL=
