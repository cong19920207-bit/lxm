# 环境变量模板，复制为 .env 并填写实际值

# === MySQL ===
MYSQL_HOST=
MYSQL_PORT=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
# Docker Compose：mysql 服务 root 密码（可选，未设时 compose 默认 root123456，须与宿主机 .env 中 MYSQL_* 一并视为一套）
# MYSQL_ROOT_PASSWORD=

# === Redis ===
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
REDIS_DB=
# 用户短期情绪缓存 TTL（秒），键 user_emotion:{user_id}；默认 3600
# REDIS_USER_EMOTION_TTL=3600

# === JWT ===
JWT_SECRET=
JWT_ALGORITHM=
JWT_EXPIRE_HOURS=

# === Open API Key（必填，长度≥32；与 JWT 无关；测试/生产各一套）===
# 生成示例：openssl rand -hex 32
OPEN_API_PEPPER=
# v1 不读取，仅预留：OPEN_API_PUBLIC_BASE_URL=http://cllxm.com

# === 火山引擎（豆包 LLM）===
VOLC_ACCESS_KEY=
VOLC_SECRET_KEY=
VOLC_ENDPOINT=
VOLC_MODEL=
# 通用 LLM 超时（秒），默认 45；日记、Agent、记忆提取、后台配置测试集等使用（与对话质量同类）
# LLM_TIMEOUT=45
# H5 对话 send/resend 同链路专用，默认 45
# LLM_TIMEOUT_CHAT=45
# 对话合并调度防抖（毫秒），默认 500
# CHAT_DEBOUNCE_MS=500

# === 阿里云（Embedding + DashVector）===
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_EMBEDDING_ENDPOINT=
ALIYUN_EMBEDDING_MODEL=
# 角色知识库 CRUD（管理后台 STEP-027）、Step2/Step6 向量检索均依赖
DASHVECTOR_API_KEY=
DASHVECTOR_ENDPOINT=
DASHVECTOR_COLLECTION_NAME=

# === 后台管理员 JWT ===
ADMIN_JWT_SECRET=your_admin_jwt_secret_here

# === 应用配置 ===
APP_DEBUG=
APP_HOST=
APP_PORT=
CORS_ORIGINS=

# Open API Key 哈希 pepper（≥32，与 JWT 无关）
OPEN_API_PEPPER=